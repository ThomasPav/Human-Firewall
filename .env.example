# Live Compete (multiplayer) backend — Supabase.
# Copy this file to .env.local and fill in your project values, then restart `npm run dev`.
# .env.local is gitignored; never commit real keys. The anon key is safe for the browser.

# Project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Project anon/public key (Project Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=

# Optional: the public origin used to build the join QR/link (defaults to window.location.origin).
# Set this to your deployed URL so phones scan a reachable address, e.g. https://human-firewall.example.com
VITE_APP_URL=
